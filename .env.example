# Sanity — Skyline Gardens org (not CoinFund)
NEXT_PUBLIC_SANITY_PROJECT_ID=0wcprvz8
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Optional: for draft preview and write access
SANITY_API_READ_TOKEN=

# Contact form (Resend recommended for Vercel)
RESEND_API_KEY=
CONTACT_EMAIL=info@skylinegardens.ca
# After verifying skylinegardens.ca in Resend, set e.g. Skyline Gardens <noreply@skylinegardens.ca>
RESEND_FROM_EMAIL=

# Products listing
# Priority: Google Sheets (if configured) → WordPress TablePress → local fallback JSON

# Google Sheets — publish the sheet (File → Share → Anyone with link → Viewer)
# Option A: spreadsheet ID + tab gid (from the sheet URL)
# Skyline Inventory: https://docs.google.com/spreadsheets/d/1XfSXT5ux6GBol-LM_ZbOyB_xV9cPtV918iG9KADheB4/edit?gid=1751729790
GOOGLE_SHEETS_PRODUCTS_ID=1XfSXT5ux6GBol-LM_ZbOyB_xV9cPtV918iG9KADheB4
GOOGLE_SHEETS_PRODUCTS_GID=1751729790
# Option B: full published CSV export URL (overrides ID/GID above)
# GOOGLE_SHEETS_PRODUCTS_CSV_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv&gid=0

# WordPress TablePress (live site products page; used when Sheets is not set)
WORDPRESS_PRODUCTS_URL=https://www.skylinegardens.ca/products/
WORDPRESS_TABLEPRESS_ID=tablepress-5
# Set WORDPRESS_PRODUCTS_URL=false to skip and use only Sheets or fallback

# How often Vercel re-fetches product data (seconds). Default: 300 (5 minutes)
PRODUCTS_REVALIDATE_SECONDS=300

# Google Maps (styled map via JavaScript API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
